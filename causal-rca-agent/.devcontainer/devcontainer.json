{
  "name": "Causal RCA Agent",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "forwardPorts": [8000, 11434],
  "portsAttributes": {
    "8000": { "label": "RCA Agent UI", "onAutoForward": "openBrowser" },
    "11434": { "label": "Ollama API",  "onAutoForward": "silent" }
  },
  "postCreateCommand": "chmod +x scripts/setup.sh scripts/run.sh && ./scripts/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ms-python.vscode-pylance"]
    }
  }
}
